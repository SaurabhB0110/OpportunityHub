@model OpportunityHub.ViewModels.CandidateEditViewModel
@{
    ViewData["Title"] = "Edit Profile";
}

<div class="container py-5 candidate-dashboard">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="card-modern">
                <div class="card-header bg-light border-bottom py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold">Edit Your Profile</h5>
                        <a href="@Url.Action("Dashboard")" class="btn btn-sm btn-outline-secondary">Cancel</a>
                    </div>
                </div>

                <div class="card-body p-4">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                            @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form method="post" enctype="multipart/form-data" novalidate>
                        @Html.AntiForgeryToken()

                        <!-- Basic Information -->
                        <section class="mb-5">
                            <h6 class="fw-bold mb-3 pb-2 border-bottom">Basic Information</h6>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="FullName" class="form-label fw-500">Full Name</label>
                                    <input asp-for="FullName" class="form-control form-control-lg" placeholder="John Doe" />
                                    <span asp-validation-for="FullName" class="form-error"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="Email" class="form-label fw-500">Email</label>
                                    <input asp-for="Email" type="email" class="form-control form-control-lg" placeholder="you@example.com" />
                                    <span asp-validation-for="Email" class="form-error"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="PhoneNumber" class="form-label fw-500">Phone Number</label>
                                    <input asp-for="PhoneNumber" type="tel" class="form-control form-control-lg" placeholder="+91 9876543210" />
                                    <span asp-validation-for="PhoneNumber" class="form-error"></span>
                                </div>

                                <div class="col-12">
                                    <label asp-for="Address" class="form-label fw-500">Address / City</label>
                                    <input asp-for="Address" class="form-control form-control-lg" placeholder="Bangalore, India" />
                                    <span asp-validation-for="Address" class="form-error"></span>
                                </div>
                            </div>
                        </section>

                        <!-- Education -->
                        <section class="mb-5">
                            <h6 class="fw-bold mb-3 pb-2 border-bottom">Education</h6>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="GraduationDegree" class="form-label fw-500">Degree</label>
                                    <input asp-for="GraduationDegree" class="form-control form-control-lg" placeholder="B.Tech in Computer Science" />
                                    <span asp-validation-for="GraduationDegree" class="form-error"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="GraduationCollege" class="form-label fw-500">College/University</label>
                                    <input asp-for="GraduationCollege" class="form-control form-control-lg" placeholder="IIT Bombay" />
                                    <span asp-validation-for="GraduationCollege" class="form-error"></span>
                                </div>

                                <div class="col-12">
                                    <label asp-for="GraduationCgpaOrPercentage" class="form-label fw-500">CGPA / Percentage</label>
                                    <input asp-for="GraduationCgpaOrPercentage" class="form-control form-control-lg" placeholder="8.5" />
                                    <span asp-validation-for="GraduationCgpaOrPercentage" class="form-error"></span>
                                </div>
                            </div>
                        </section>

                        <!-- Skills & Resume -->
                        <section class="mb-5">
                            <h6 class="fw-bold mb-3 pb-2 border-bottom">Skills & Resume</h6>

                            <div class="mb-4">
                                <label asp-for="Skills" class="form-label fw-500">Skills</label>
                                <textarea asp-for="Skills" class="form-control form-control-lg" rows="3" placeholder="C#, JavaScript, SQL, ASP.NET Core (comma-separated)"></textarea>
                                <small class="d-block text-muted mt-2">Enter your skills separated by commas</small>
                                <span asp-validation-for="Skills" class="form-error"></span>
                            </div>

                            <div>
                                <label asp-for="Resume" class="form-label fw-500">Resume</label>
                                @if (!string.IsNullOrEmpty(Model.ResumeUrl))
                                {
                                    <div class="alert alert-info d-flex justify-content-between align-items-center mb-3">
                                        <div>
                                            <strong>Current Resume:</strong><br />
                                            <small>@Model.ResumeUrl.Split('/').Last()</small>
                                        </div>
                                        <a href="@Model.ResumeUrl" target="_blank" class="btn btn-sm btn-outline-info">View</a>
                                    </div>
                                }
                                <input asp-for="Resume" type="file" class="form-control form-control-lg" accept=".pdf,.doc,.docx" />
                                <span asp-validation-for="Resume" class="form-error"></span>
                                <small class="d-block text-muted mt-2">Allowed: PDF, DOC, DOCX • Max 5 MB</small>
                            </div>
                        </section>

                        <div class="d-flex gap-2 justify-content-between">
                            <div>
                                <button type="submit" class="btn btn-primary btn-lg">Save Changes</button>
                            </div>
                            <a href="@Url.Action("Dashboard")" class="btn btn-outline-secondary btn-lg">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
