@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Saved Jobs";
}
<section class="section">
    <div class="shell">
        <div class="section-heading">
            <div>
                <span class="kicker">MY CAREER</span>
                <h2>Saved Jobs</h2>
            </div>
        </div>

        @if (TempData["Success"] is string success)
        {
            <div class="success-banner"><span>✓</span><div><b>Success</b><p>@success</p></div></div>
        }
        @if (TempData["Error"] is string error)
        {
            <div class="alert alert-danger"><strong>Error:</strong> @error</div>
        }

        <table class="table">
            <thead>
                <tr>
                    <th>Job Title</th>
                    <th>Company</th>
                    <th>Location</th>
                    <th>Category</th>
                    <th>Posted</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="6">You have no saved jobs.</td></tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        var opp = (Opportunity?)item.Opportunity;
                        <tr>
                            <td>
                                @if (opp != null)
                                {
                                    <b>@opp.Title</b>
                                }
                                else
                                {
                                    <b>Job removed</b>
                                }
                            </td>
                            <td>@(opp?.Company ?? "—")</td>
                            <td>@(opp?.Location ?? "—")</td>
                            <td>@(opp?.Category ?? "—")</td>
                            <td>
                                @if (opp != null)
                                {
                                    @opp.PostedAt.ToString("dd MMM yyyy")
                                }
                                else
                                {
                                    <em>N/A</em>
                                }
                            </td>
                            <td>
                                @if (opp != null)
                                {
                                    <a class="btn btn-outline-primary" asp-controller="Jobs" asp-action="Details" asp-route-id="@opp.Id">View Details</a>
                                }
                                <form asp-controller="Jobs" asp-action="UnsaveJob" method="post" style="display:inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="returnUrl" value="@Url.Action("SavedJobs", "Candidate")" />
                                    <button class="btn btn-danger">Remove</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>