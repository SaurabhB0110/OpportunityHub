@{
    var success = TempData["Success"]?.ToString();
    var error = TempData["Error"]?.ToString();
    var info = TempData["Info"]?.ToString();
    var warning = TempData["Warning"]?.ToString();
}

@if (!string.IsNullOrEmpty(success))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <span>?</span>
        <div class="alert-message">
            @success
            <button type="button" class="alert-close" data-bs-dismiss="alert" aria-label="Close">×</button>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-error alert-dismissible fade show" role="alert">
        <span>!</span>
        <div class="alert-message">
            @error
            <button type="button" class="alert-close" data-bs-dismiss="alert" aria-label="Close">×</button>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(info))
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        <span>?</span>
        <div class="alert-message">
            @info
            <button type="button" class="alert-close" data-bs-dismiss="alert" aria-label="Close">×</button>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(warning))
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <span>?</span>
        <div class="alert-message">
            @warning
            <button type="button" class="alert-close" data-bs-dismiss="alert" aria-label="Close">×</button>
        </div>
    </div>
}