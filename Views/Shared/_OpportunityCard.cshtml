@model Opportunity

<article class="card shadow-sm h-100">
    <div class="card-body d-flex flex-column">
        <div class="d-flex align-items-start mb-3">
            <div class="me-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center text-white" style="width:56px;height:56px;background:@Model.LogoColor;font-weight:600;font-size:18px;">
                    @Model.Initials
                </div>
            </div>

            <div class="flex-grow-1">
                <h5 class="h6 mb-1"><a class="text-decoration-none text-dark" asp-controller="Jobs" asp-action="Details" asp-route-id="@Model.Id">@Model.Title</a></h5>
                <div class="text-muted small">@Model.Company</div>
                <div class="mt-2">
                    <span class="badge bg-light text-dark me-2"><i class="me-1">⌖</i>@Model.Location</span>
                    <span class="badge bg-light text-dark me-2"><i class="me-1">◷</i>@Model.Type</span>
                    <span class="badge bg-light text-dark"><i class="me-1">◈</i>@Model.Compensation</span>
                </div>
            </div>

            <div class="ms-3">
                <button type="button" class="btn btn-outline-secondary btn-sm save-button" data-save-id="@Model.Id" aria-label="Save @Model.Title">♡</button>
            </div>
        </div>

        <p class="text-muted small mb-3">@(Model.Description?.Length > 160 ? Model.Description.Substring(0,160) + "…" : Model.Description)</p>

        <div class="mt-auto d-flex justify-content-between align-items-center">
            <div class="small text-muted">
                <strong class="me-2">@Model.Applicants</strong> applicants • <span>@Model.PostedLabel</span>
            </div>
            <a class="btn btn-sm btn-primary" asp-controller="Jobs" asp-action="Details" asp-route-id="@Model.Id">View details</a>
        </div>
    </div>
</article>
