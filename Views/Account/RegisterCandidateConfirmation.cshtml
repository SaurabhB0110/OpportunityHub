@{
    ViewData["Title"] = "Confirm Your Email";
    var email = ViewData["Email"]?.ToString() ?? "";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-5 text-center">
                    <div class="mb-4">
                        <i class="bi bi-envelope-check" style="font-size: 3rem; color: #28a745;"></i>
                    </div>

                    <h2 class="mb-3">Verify Your Email</h2>

                    <p class="text-muted mb-4">
                        We've sent a confirmation link to <strong>@email</strong>
                    </p>

                    <div class="alert alert-info" role="alert">
                        <h5 class="alert-heading">What's next?</h5>
                        <ul class="text-start mb-0">
                            <li>Check your email inbox for a message from OpportunityHub</li>
                            <li>Click the "Confirm Email" button in the email</li>
                            <li>Once confirmed, you can sign in and start applying for jobs</li>
                        </ul>
                    </div>

                    <p class="text-muted small mb-4">
                        <strong>Tip:</strong> Check your spam or junk folder if you don't see the email in your inbox.
                    </p>

                    <div class="d-flex gap-2 justify-content-center">
                        <a href="@Url.Action("Login", "Account")" class="btn btn-primary">Go to Sign In</a>
                        <a href="@Url.Action("ResendConfirmationEmail", "Account", new { email = email })" class="btn btn-outline-secondary">Resend Email</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>