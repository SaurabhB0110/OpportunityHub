@{
    ViewData["Title"] = "Resend Confirmation Email";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h3 class="mb-4">Resend Confirmation Email</h3>

                    <p class="text-muted mb-4">
                        Enter your email address and we'll send you a new confirmation link.
                    </p>

                    <form asp-action="ResendConfirmationEmail" method="post">
                        <div class="mb-3">
                            <label for="email" class="form-label">Email Address</label>
                            <input type="email" class="form-control" id="email" name="email" 
                                   value="@(ViewData["Email"]?.ToString() ?? "")" required />
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Send Confirmation Email</button>

                        <div class="text-center mt-3">
                            <a href="@Url.Action("Login", "Account")" class="link-secondary">Back to Sign In</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>