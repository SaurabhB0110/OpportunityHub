@model OpportunityHub.ViewModels.RegisterEmployerViewModel

@{
    ViewData["Title"] = "Register as Employer";
}

<div class="auth-page">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="auth-card">
                    <div class="auth-card-body p-4">
                        <h2 class="mb-3">Register your company</h2>

                        <form asp-action="RegisterEmployer" method="post" enctype="multipart/form-data">
                            <div asp-validation-summary="All" class="form-error mb-2"></div>

                            <div class="mb-3">
                                <label asp-for="CompanyName" class="form-label visually-hidden"></label>
                                <input asp-for="CompanyName" class="form-control" placeholder="Company name" />
                                <span asp-validation-for="CompanyName" class="form-error text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="CompanyAddress" class="form-label visually-hidden"></label>
                                <input asp-for="CompanyAddress" class="form-control" placeholder="Address" />
                                <span asp-validation-for="CompanyAddress" class="form-error text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="CompanyDescription" class="form-label visually-hidden"></label>
                                <textarea asp-for="CompanyDescription" class="form-control" rows="3" placeholder="Company description"></textarea>
                                <span asp-validation-for="CompanyDescription" class="form-error text-danger small"></span>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Website" class="form-label visually-hidden"></label>
                                    <input asp-for="Website" class="form-control" placeholder="https://example.com" />
                                    <span asp-validation-for="Website" class="form-error text-danger small"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="ContactNumber" class="form-label visually-hidden"></label>
                                    <input asp-for="ContactNumber" class="form-control" placeholder="Contact number" />
                                    <span asp-validation-for="ContactNumber" class="form-error text-danger small"></span>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Email" class="form-label visually-hidden"></label>
                                <input asp-for="Email" class="form-control" placeholder="Email address" />
                                <span asp-validation-for="Email" class="form-error text-danger small"></span>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Password" class="form-label visually-hidden"></label>
                                    <input asp-for="Password" class="form-control" placeholder="Password" />
                                    <span asp-validation-for="Password" class="form-error text-danger small"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="ConfirmPassword" class="form-label visually-hidden"></label>
                                    <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirm password" />
                                    <span asp-validation-for="ConfirmPassword" class="form-error text-danger small"></span>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label asp-for="EmployerId" class="form-label visually-hidden"></label>
                                <input asp-for="EmployerId" class="form-control" placeholder="Employer ID (optional)" />
                                <span asp-validation-for="EmployerId" class="form-error text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="VerificationDocument" class="form-label">Verification Document (PDF/JPG/PNG)</label>
                                <input asp-for="VerificationDocument" type="file" class="form-control" />
                                <span asp-validation-for="VerificationDocument" class="form-error text-danger small"></span>
                            </div>

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary">Register Company</button>
                                <a asp-controller="Account" asp-action="Login" class="btn btn-link">Already have an account?</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}