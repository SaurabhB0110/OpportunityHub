@{
    ViewData["Title"] = "Confirmation Email Sent";
    var message = ViewData["Message"]?.ToString() ?? "A confirmation link has been sent.";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-5 text-center">
                    <div class="mb-4">
                        <i class="bi bi-envelope-check" style="font-size: 3rem; color: #28a745;"></i>
                    </div>

                    <h2 class="mb-3">Check Your Email</h2>

                    <p class="text-muted mb-4">
                        @message
                    </p>

                    <p class="text-muted small mb-4">
                        <strong>Tip:</strong> Check your spam or junk folder if you don't see the email.
                    </p>

                    <a href="@Url.Action("Login", "Account")" class="btn btn-primary">Go to Sign In</a>
                </div>
            </div>
        </div>
    </div>
</div>