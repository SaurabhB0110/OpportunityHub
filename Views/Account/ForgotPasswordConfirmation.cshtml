@{
    ViewData["Title"] = "Password Reset Requested";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center p-5">
                    <h2>Check your email</h2>
                    <p class="text-muted">If an account exists for the provided email, a password reset link has been sent.</p>
                    <a href="@Url.Action("Login", "Account")" class="btn btn-primary">Back to sign in</a>
                </div>
            </div>
        </div>
    </div>
</div>
