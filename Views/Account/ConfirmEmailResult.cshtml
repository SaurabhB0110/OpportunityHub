@{
    ViewData["Title"] = "Email Confirmation";
    var successMessage = ViewData["SuccessMessage"]?.ToString();
    var errorMessage = ViewData["ErrorMessage"]?.ToString();
    bool isSuccess = !string.IsNullOrEmpty(successMessage);
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-5 text-center">
                    @if (isSuccess)
                    {
                        <div class="mb-4">
                            <i class="bi bi-check-circle-fill" style="font-size: 3rem; color: #28a745;"></i>
                        </div>
                        <h2 class="mb-3 text-success">Email Confirmed!</h2>
                        <p class="text-muted mb-4">@successMessage</p>
                        <a href="@Url.Action("Login", "Account")" class="btn btn-primary">Sign In Now</a>
                    }
                    else
                    {
                        <div class="mb-4">
                            <i class="bi bi-exclamation-circle-fill" style="font-size: 3rem; color: #dc3545;"></i>
                        </div>
                        <h2 class="mb-3 text-danger">Confirmation Failed</h2>
                        <p class="text-muted mb-4">@errorMessage</p>
                        <div class="d-flex gap-2 justify-content-center">
                            <a href="@Url.Action("Login", "Account")" class="btn btn-primary">Back to Sign In</a>
                            <a href="@Url.Action("ResendConfirmationEmail", "Account")" class="btn btn-outline-secondary">Request New Link</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>